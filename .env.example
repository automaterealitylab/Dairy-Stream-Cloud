# Top-level environment variables template for Dairy Automation System
# Copy to `.env` and populate with real values. Do NOT commit `.env`.

# ================================
# Backend / Server
# ================================
PORT=4000
NODE_ENV=development

# ================================
# JWT Configuration
# ================================
JWT_SECRET=REPLACE_ME
JWT_EXPIRE=7d

# ================================
# Supabase Configuration
# ================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=REPLACE_ME
SUPABASE_SERVICE_KEY=REPLACE_ME
SUPABASE_PROJECT_REF=REPLACE_ME
SUPABASE_REGION=us-east-1

# Optional: Direct DB connection (used for migrations / setup)
SUPABASE_DB_URL=postgresql://postgres:REPLACE_ME@host:6543/postgres

# ================================
# Frontend (Vite)
# ================================
VITE_API_URL=http://localhost:4000

# ================================
# Email Configuration
# ================================
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=REPLACE_ME

# ================================
# External Services
# ================================
KICKBOX_API_KEY=REPLACE_ME
