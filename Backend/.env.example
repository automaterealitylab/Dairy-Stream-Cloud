PORT=4000
JWT_SECRET=replace_with_long_random_secret

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Direct UPI platform integrations
FRONTEND_URL=http://localhost:5173
GOOGLE_VISION_API_KEY=
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
WHATSAPP_MAX_ATTEMPTS=3
WHATSAPP_RETRY_DELAY_MS=300000
SENTRY_DSN=
IFSC_LOOKUP_TIMEOUT_MS=6000
BANK_VERIFICATION_PROVIDER=cashfree
BANK_VERIFICATION_TIMEOUT_MS=10000
BANK_ACCOUNT_ENCRYPTION_KEY=
BANK_VERIFICATION_ENCRYPTION_KEY=
BANK_VERIFICATION_CACHE_SECRET=
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
CASHFREE_BASE_URL=https://api.cashfree.com/verification

# Legacy marketplace-only keys. Leave empty for the direct UPI dairy billing model.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

CORS_ORIGINS=http://localhost:5173
MARKETPLACE_RATE_LIMIT_PER_MINUTE=60
WEBHOOK_RATE_LIMIT_PER_MINUTE=300
MARKETPLACE_TAX_PERCENT=0
MARKETPLACE_DELIVERY_FEE=0
MARKETPLACE_RECONCILIATION_CRON="*/30 * * * *"
MARKETPLACE_RECONCILIATION_LIMIT=100

# Enterprise runtime
REDIS_URL=redis://127.0.0.1:6379
REDIS_ENABLED=false
START_QUEUE_WORKERS_IN_API=false
QUEUE_WORKER_CONCURRENCY=5
QUEUE_JOB_ATTEMPTS=7
QUEUE_JOB_BACKOFF_MS=5000
DISTRIBUTED_LOCK_TTL_MS=120000

# Security hardening
API_REQUEST_SIGNING_REQUIRED=false
API_REQUEST_SIGNING_SECRET=replace_with_long_random_secret
CSRF_PROTECTION_REQUIRED=false
RAZORPAY_WEBHOOK_IP_ALLOWLIST=
RAZORPAY_WEBHOOK_REPLAY_WINDOW_SECONDS=86400
SECURITY_AUDIT_DB_ENABLED=false
BOT_PROTECTION_RATE_PER_MINUTE=600
FRAUD_HIGH_VALUE_ORDER_INR=50000

# Razorpay resilience
RAZORPAY_API_ATTEMPTS=3
RAZORPAY_API_BASE_BACKOFF_MS=750
RAZORPAY_API_MAX_BACKOFF_MS=15000
RAZORPAY_CIRCUIT_FAILURE_THRESHOLD=5
RAZORPAY_CIRCUIT_OPEN_MS=60000
